# ╔══════════════════════════════════════════════════════════════╗
# ║          SalesPro CRM - Environment Variables Guide          ║
# ╚══════════════════════════════════════════════════════════════╝
#
# IMPORTANT: Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git — it's already in .gitignore.
#
# Get these values from your Supabase Dashboard:
#   https://app.supabase.com → Your Project → Settings → API
#

# ── Supabase Configuration (REQUIRED) ──────────────────────────
# The URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# The anonymous/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# The service role key (SECRET — server-side only, bypasses RLS)
# ⚠️ NEVER expose this in the browser or client-side code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
