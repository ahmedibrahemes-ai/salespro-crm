generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id            String   @id @default(cuid())
  name          String
  phone         String
  email         String   @default("")
  source        String   @default("website")
  status        String   @default("new")
  value         Float    @default(0)
  probability   Int      @default(20)
  hot           Boolean  @default(false)
  notes         String   @default("[]")
  assignedTo    String   @default("")
  company       String   @default("")
  location      String   @default("")
  isArchived    Boolean  @default(false)
  lastContactAt DateTime @default(now())
  nextFollowUp  DateTime?
  followUpType  String   @default("") // call, meeting, whatsapp, email
  lostReason    String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activities Activity[]
  messages   ChatMessage[]
}

model Activity {
  id        String   @id @default(cuid())
  leadId    String
  type      String   // call, whatsapp, email, note
  text      String
  score     Float    @default(0)
  duration  Int      @default(0) // in seconds
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  nameAr    String   @default("")
  role      String   @default("sales")
  initials  String   @default("")
  points    Int      @default(0)
  deals     Int      @default(0)
  revenue   Float    @default(0)
  calls     Int      @default(0)
  convRate  Float    @default(0)
  avatar    String   @default("")
  badges    String   @default("[]") // JSON array of badge names
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Target {
  id            String   @id @default(cuid())
  month         Int
  year          Int
  targetAmount  Float    @default(0)
  achievedAmount Float   @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  leadId    String
  fromMe    Boolean  @default(false)
  text      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}
