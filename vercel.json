{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "bun install",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/leads/route.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "src/app/api/stats/route.ts": {
      "maxDuration": 20,
      "memory": 512
    },
    "src/app/api/ai/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/notifications/route.ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "src/app/api/transfers/route.ts": {
      "maxDuration": 15,
      "memory": 512
    }
  },
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/stats",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, max-age=60, stale-while-revalidate=120"
        }
      ]
    },
    {
      "source": "/api/leads",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, max-age=30, stale-while-revalidate=60"
        }
      ]
    },
    {
      "source": "/api/team",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, max-age=300, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/api/notifications",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, max-age=10, stale-while-revalidate=30"
        }
      ]
    }
  ]
}
